# =============================================================================
#  Collaborative Document Editor — backend & collab server environment template
# =============================================================================
#  Copy this file to `.env` and fill in the values that don't have sane defaults.
#  Frontend (Vite) envs live in `frontend/.env.example`.
#
#  Minimum you MUST set for a full production run:
#    JWT_SECRET, GROQ_API_KEY, COLLAB_SYSTEM_USER_ID, DATABASE_URL.
#
#  Quick local start (no database, no Groq key required):
#    - Leave DATABASE_URL blank          → backend + collab run in memory.
#    - Set AI_FAKE_MODE=true             → AI streams mocked tokens.
#  Everything else below can keep the defaults provided here.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (OPTIONAL for local dev)
# -----------------------------------------------------------------------------
# Connection string read by BOTH the FastAPI backend (asyncpg) and the
# Node collab server (pg). Leave blank to run entirely in memory — the
# backend falls back to InMemoryDocumentStore and the collab server
# disables snapshot persistence. Required for production / Render deploys.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/collab_editor


# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
# REQUIRED. Shared between FastAPI (issues tokens) and the collab server
# (verifies WebSocket upgrade tokens). Use at least 32 random chars.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# HMAC algorithm. HS256 is the only one wired up in auth.py.
JWT_ALGORITHM=HS256

# Access-token lifetime. Short on purpose — refresh tokens handle long sessions.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh-token lifetime (session persistence across tab reloads).
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Lifetime of the doc-scoped token minted by POST /api/realtime/session and
# used in the collab WebSocket URL. Short-lived by design (closes the
# A1-review replay hole — token only works for one specific doc_id).
REALTIME_TOKEN_TTL_SECONDS=600


# -----------------------------------------------------------------------------
# AI / Groq
# -----------------------------------------------------------------------------
# REQUIRED for real AI streaming. Get a key from https://console.groq.com.
# Leave the placeholder and set AI_FAKE_MODE=true below to stub the AI.
GROQ_API_KEY=replace-with-your-groq-key

# Primary model used for rewrite/summarize/translate/restructure/continue.
GROQ_MODEL=llama-3.3-70b-versatile

# Used by ai/service.py when the primary model returns an error.
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Upstream HTTP timeout for the Groq SDK.
GROQ_REQUEST_TIMEOUT_SECONDS=30

# Per-user daily token cap enforced in ai/quota.py.
AI_PER_USER_DAILY_TOKEN_LIMIT=50000

# Organization-wide monthly token budget enforced in ai/quota.py.
AI_ORG_MONTHLY_TOKEN_BUDGET=1000000

# Safety cap on a single request's completion token count.
AI_PER_REQUEST_TOKEN_CAP=4000

# When true (default), every /api/ai/* route requires a valid bearer token.
# Set to false for unauthenticated demos — the dev bootstrap user is then
# used as the caller. Playwright CI uses this path.
AI_REQUIRE_AUTH=true

# Set to true to swap GroqAIService for FakeAIService. Useful for CI,
# Playwright, and running the app without a Groq key. AI features still
# stream tokens, they just come from a canned response.
AI_FAKE_MODE=false

# Dev user seeded at backend startup. Also the fallback "caller" when
# AI_REQUIRE_AUTH=false. Override if you want a different preview account.
DEV_BOOTSTRAP_EMAIL=atharv.dev@local
DEV_BOOTSTRAP_PASSWORD=atharv-preview-pass


# -----------------------------------------------------------------------------
# HTTP / CORS / Ports
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed by FastAPI CORS middleware.
# Add the production frontend URL here before deploying.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Port the FastAPI backend listens on (used by run.sh and uvicorn).
API_PORT=4000

# Public WebSocket URL returned inside POST /api/realtime/session responses.
# The frontend never constructs this itself — it uses whatever ws_url the
# backend hands back. Point this at the deployed collab-server URL in prod.
COLLAB_WS_URL=ws://127.0.0.1:1234


# -----------------------------------------------------------------------------
# Collab server (Node)
# -----------------------------------------------------------------------------
# Port the y-websocket collab server listens on.
COLLAB_PORT=1234

# UUID of the system user under which the collab server writes snapshots
# to `document_versions`. Must exist in the users table when DATABASE_URL
# is set (see infra/init.sql → INSERT example). Ignored in memory mode.
COLLAB_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001

# Standard Node env. Use "production" on Render, "development" locally.
NODE_ENV=development
