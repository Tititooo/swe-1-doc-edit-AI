# ============================================================
# Root .env companion values for local backend + collab development.
# Copy .env.example at repo root to .env and fill in values.
# NEVER commit .env to the repository.
# ============================================================

# PostgreSQL connection string used by both the FastAPI backend and collab server.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/collab_editor

# FastAPI / Groq
GROQ_API_KEY=replace-with-a-real-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_REQUEST_TIMEOUT_SECONDS=30
AI_PER_USER_DAILY_TOKEN_LIMIT=50000
AI_PER_REQUEST_TOKEN_CAP=4000
AI_REQUIRE_AUTH=false
DEV_BOOTSTRAP_EMAIL=temiko.dev@local
DEV_BOOTSTRAP_PASSWORD=temiko-preview-pass
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_PORT=4000

# Port the y-websocket server listens on (default: 1234 for local dev).
COLLAB_PORT=1234

# JWT secret — must match the FastAPI backend's JWT_SECRET exactly.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# UUID of the "system" service account user in the users table
# Used as created_by for auto-snapshots written by the collab server
# Use the fixed preview UUID below and insert the matching row into users before
# depending on collab snapshot writes in local or Render environments.
COLLAB_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001

# Set to "production" on Render (enables SSL for Postgres)
NODE_ENV=development
