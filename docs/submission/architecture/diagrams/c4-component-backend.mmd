---
title: C4 Level 3 - FastAPI Backend Components
---
graph TB
    spa["&lt;&lt;container&gt;&gt;<br/><b>React SPA</b><br/><small>Sends HTTP requests,<br/>receives SSE streams</small>"]

    groq["&lt;&lt;external system&gt;&gt;<br/><b>Groq LLM API</b><br/><small>Streams completions</small>"]

    db[("&lt;&lt;database&gt;&gt;<br/><b>PostgreSQL</b><br/><small>Persistent storage</small>")]

    subgraph api["FastAPI Backend"]
        app["&lt;&lt;component&gt;&gt;<br/><b>FastAPI App</b><br/><small>backend/api/main.py<br/>─────────────────<br/>Route registration, CORS,<br/>lifespan, exception handling</small>"]
        schemas["&lt;&lt;component&gt;&gt;<br/><b>Schema Layer</b><br/><small>backend/api/schemas.py<br/>─────────────────<br/>Pydantic request/response<br/>contracts</small>"]
        auth["&lt;&lt;component&gt;&gt;<br/><b>Auth Module</b><br/><small>backend/api/auth.py<br/>─────────────────<br/>Password hashing, JWT<br/>access and refresh tokens</small>"]
        runtime["&lt;&lt;component&gt;&gt;<br/><b>Runtime Service</b><br/><small>backend/api/runtime.py<br/>─────────────────<br/>Login, registration, doc<br/>metadata, permissions,<br/>AI history, quotas, admin</small>"]
        store["&lt;&lt;component&gt;&gt;<br/><b>Document Content Store</b><br/><small>backend/api/store.py<br/>─────────────────<br/>REST content projection,<br/>version IDs, export</small>"]
        aisvc["&lt;&lt;component&gt;&gt;<br/><b>AI Service</b><br/><small>backend/ai/service.py<br/>─────────────────<br/>Feature dispatch, streaming<br/>and full completions</small>"]
        prompt["&lt;&lt;component&gt;&gt;<br/><b>Prompt Engine</b><br/><small>backend/ai/prompts.py<br/>─────────────────<br/>Templates for rewrite,<br/>summarize, translate,<br/>restructure, continue</small>"]
        groqclient["&lt;&lt;component&gt;&gt;<br/><b>Groq API Client</b><br/><small>backend/ai/groq_client.py<br/>─────────────────<br/>Async HTTP, streaming,<br/>timeout handling</small>"]
    end

    spa -->|"HTTPS REST + SSE"| app
    app --> schemas
    app --> auth
    app --> runtime
    app --> store
    app --> aisvc
    aisvc --> prompt
    aisvc --> groqclient
    groqclient -->|"HTTPS"| groq
    runtime -->|"SQL"| db
    store -->|"SQL"| db

