# =============================================================================
#  Frontend (Vite) environment template
# =============================================================================
#  Copy this file to `frontend/.env` if you need to override the defaults.
#  Every variable here is OPTIONAL — the app falls back to the values shown
#  below when the env var is unset (see frontend/src/api/client.ts,
#  frontend/src/hooks/useAuth.ts).
#
#  Running `./run.sh` from the repo root does NOT require this file.
# =============================================================================


# -----------------------------------------------------------------------------
# API configuration
# -----------------------------------------------------------------------------
# Base URL the Axios client hits. Default: http://localhost:4000/api
# Change this when the backend runs on a non-default port or a remote host
# (e.g. https://collab-editor-backend-ghfl.onrender.com/api in production).
VITE_API_BASE_URL=http://localhost:4000/api

# When "true", swaps in src/api/mockAPI.ts — useful for UI-only iteration
# without running the backend. Default: false.
VITE_ENABLE_MOCK_API=false

# Declared in vite-env.d.ts for documentation, currently NOT read by the
# app — the backend sends the authoritative ws_url in POST /api/realtime/
# session responses. Kept here as a reminder for manual overrides.
VITE_COLLAB_WS_URL=ws://localhost:1234


# -----------------------------------------------------------------------------
# Dev auth bootstrap
# -----------------------------------------------------------------------------
# When "true", the frontend silently logs in as the dev bootstrap user on
# first load — skips the register/login screen. Use for local demos only.
# Default: false.
VITE_DEV_AUTOLOGIN=false

# Credentials used when VITE_DEV_AUTOLOGIN=true. Must match the backend's
# DEV_BOOTSTRAP_EMAIL / DEV_BOOTSTRAP_PASSWORD in the root .env.
VITE_DEV_BOOTSTRAP_EMAIL=atharv.dev@local
VITE_DEV_BOOTSTRAP_PASSWORD=atharv-preview-pass
